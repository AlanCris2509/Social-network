# Copy this file to .env and fill in your values

# PostgreSQL password
DB_PASSWORD=123456

# JWT secret — change this to a long random string in production
JWT_SECRET=ThisIsADemoSecretKeyChangeInProd1234

# Google OAuth2 — get these from https://console.cloud.google.com/
# Under "APIs & Services > Credentials > OAuth 2.0 Client IDs"
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
